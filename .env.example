# Google Apps Script Web App URL (server-side) - Legacy, optional
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google Sheet ID - extracted from Google Sheets URL (for courses data)
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# Public Google Apps Script URL (client-side fallback)
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Firebase Admin SDK (server-side) - Get from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# JWT Secret for session management (minimum 32 characters)
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
